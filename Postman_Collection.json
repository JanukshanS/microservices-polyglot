                        },
                        "url": "http://localhost:8080/items"
                    }
                }
            ]
        },
        {
            "name": "Order Service",
            "item": [
                {
                    "name": "Get All Orders",
                    "request": {
                        "method": "GET",
                        "url": "http://localhost:8080/orders"
                    }
                },
                {
                    "name": "Get Order By ID",
                    "request": {
                        "method": "GET",
                        "url": "http://localhost:8080/orders/1"
                    }
                },
                {
                    "name": "Place Order",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"item\": \"Laptop\",\n    \"quantity\": 2\n}"
                        },
                        "url": "http://localhost:8080/orders"
                    }
                }
            ]
        },
